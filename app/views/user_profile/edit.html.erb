<div class="max-w-md mx-auto">

  <h1 class="text-2xl font-serif font-bold text-gray-900 mb-8">My Profile</h1>

  <% if flash[:notice].present? %>
    <div class="bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 mb-6">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if current_user.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 mb-6">
      <% current_user.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 shadow-sm">
    <div class="h-1 bg-red-600 w-full"></div>
    <div class="p-8">

      <%= form_with model: current_user, url: user_profile_path, method: :patch, multipart: true, class: "space-y-6" do |f| %>

        <%# Avatar %>
        <div>
          <label class="block text-xs font-semibold tracking-widest uppercase text-gray-500 mb-3">Profile Photo</label>
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 rounded-full overflow-hidden bg-gray-800 flex items-center justify-center shrink-0">
              <% if current_user.avatar.attached? %>
                <%= image_tag current_user.avatar, class: "w-full h-full object-cover" %>
              <% else %>
                <span class="text-lg font-bold text-white leading-none">
                  <%= current_user.name.split.map(&:first).first(2).join.upcase %>
                </span>
              <% end %>
            </div>
            <div class="flex-1">
              <%= f.file_field :avatar, accept: "image/*",
                class: "block w-full text-xs text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:border-0 file:text-xs file:font-semibold file:bg-gray-900 file:text-white hover:file:bg-gray-700 file:cursor-pointer" %>
              <p class="text-xs text-gray-400 mt-1">JPG, PNG or GIF · Max 5 MB</p>
            </div>
          </div>
        </div>

        <hr class="border-gray-100">

        <%# Name %>
        <div>
          <label class="block text-xs font-semibold tracking-widest uppercase text-gray-500 mb-2">Name</label>
          <%= f.text_field :name, required: true,
            class: "w-full border border-gray-200 px-3 py-2.5 text-sm focus:border-gray-900 focus:outline-none focus:ring-0 transition-colors" %>
        </div>

        <%# Email (read-only) %>
        <div>
          <label class="block text-xs font-semibold tracking-widest uppercase text-gray-500 mb-2">Email</label>
          <p class="px-3 py-2.5 text-sm text-gray-500 border border-gray-100 bg-gray-50"><%= current_user.email %></p>
        </div>

        <hr class="border-gray-100">

        <p class="text-xs text-gray-400">Leave password fields blank to keep your current password.</p>

        <%# New password %>
        <div>
          <label class="block text-xs font-semibold tracking-widest uppercase text-gray-500 mb-2">New Password</label>
          <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full border border-gray-200 px-3 py-2.5 text-sm focus:border-gray-900 focus:outline-none focus:ring-0 transition-colors",
            placeholder: "••••••••" %>
        </div>

        <%# Confirm password %>
        <div>
          <label class="block text-xs font-semibold tracking-widest uppercase text-gray-500 mb-2">Confirm New Password</label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full border border-gray-200 px-3 py-2.5 text-sm focus:border-gray-900 focus:outline-none focus:ring-0 transition-colors",
            placeholder: "••••••••" %>
        </div>

        <%= f.submit "Save Changes",
          class: "w-full bg-gray-900 text-white text-xs font-semibold tracking-widest uppercase px-6 py-3 hover:bg-gray-700 transition-colors cursor-pointer" %>

      <% end %>
    </div>
  </div>

  <p class="text-center mt-6">
    <%= link_to user_logout_path, data: { turbo_method: :delete },
      class: "text-xs text-gray-400 hover:text-red-500 transition-colors" do %>
      Sign out
    <% end %>
  </p>

</div>
