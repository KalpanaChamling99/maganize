<% content_for :page_title, "Members" %>

<div class="bg-white border border-gray-200">
  <% if @members.any? %>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-100 text-xs font-semibold tracking-widest uppercase text-gray-400">
          <th class="text-left px-6 py-3">Name</th>
          <th class="text-left px-6 py-3">Email</th>
          <th class="text-left px-6 py-3">Role</th>
          <th class="text-left px-6 py-3 hidden md:table-cell">Joined</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @members.each do |member| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center shrink-0">
                  <span class="text-[10px] font-bold text-gray-600 leading-none">
                    <%= member.name.split.map(&:first).first(2).join.upcase %>
                  </span>
                </div>
                <p class="font-medium text-gray-900"><%= member.name %></p>
              </div>
            </td>
            <td class="px-6 py-4 text-gray-500"><%= member.email %></td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase bg-gray-100 text-gray-700">
                <%= member.role %>
              </span>
            </td>
            <td class="px-6 py-4 hidden md:table-cell text-gray-400 text-xs">
              <%= member.created_at.strftime("%b %-d, %Y") %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= button_to admin_member_path(member), method: :delete,
                data: { turbo_confirm: "Delete member \"#{member.name}\"? This cannot be undone." },
                class: "inline-flex items-center justify-center w-8 h-8 rounded bg-red-50 text-red-400 hover:bg-red-100 hover:text-red-700 transition-colors cursor-pointer",
                form: { style: "display:inline" },
                title: "Delete" do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-6 py-16 text-center">
      <p class="text-gray-400">No members have signed up yet.</p>
    </div>
  <% end %>
</div>
