<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-serif font-bold text-gray-900 mb-8">Edit Comment</h1>

  <% if @comment.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 mb-6">
      <% @comment.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 shadow-sm">
    <div class="h-1 bg-red-600 w-full"></div>
    <div class="p-8">
      <%= form_with model: @comment, url: comment_path(@comment), method: :patch, class: "space-y-5" do |f| %>
        <div>
          <label class="block text-xs font-semibold tracking-widest uppercase text-gray-500 mb-2">Comment</label>
          <%= f.text_area :body, rows: 5, required: true,
            class: "w-full border border-gray-200 px-3 py-2.5 text-sm focus:border-gray-900 focus:outline-none focus:ring-0 transition-colors resize-none" %>
        </div>
        <div class="flex items-center gap-3">
          <%= f.submit "Save Changes",
            class: "px-6 py-2.5 text-sm font-semibold bg-gray-900 text-white hover:bg-gray-700 transition-colors cursor-pointer" %>
          <%= link_to "Cancel", article_path(@article, anchor: "comment-#{@comment.id}"),
            class: "text-sm text-gray-400 hover:text-gray-700 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
